# strava-mcp configuration template. Copy to .env and fill in your values.
# Get client credentials at https://www.strava.com/settings/api

# --- Strava app credentials ---
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# --- Bootstrap OAuth tokens (optional; `uv run strava-mcp auth` will populate the DB) ---
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=
STRAVA_TOKEN_EXPIRES_AT=
STRAVA_TOKEN_SCOPE=

# --- OAuth flow ---
STRAVA_SCOPES=read,read_all,profile:read_all,activity:read,activity:read_all
OAUTH_REDIRECT_HOST=127.0.0.1
OAUTH_REDIRECT_PORT=8721

# --- Local database ---
STRAVA_DB_PATH=./.database/strava.db

# --- MCP HTTP server ---
MCP_HOST=127.0.0.1
MCP_PORT=8720

# --- Sync tuning ---
SYNC_MAX_REQUESTS=900
